{% sw_extends '@Storefront/storefront/base.html.twig' %}

{% block base_main_inner %}
<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card mt-5">
                <div class="card-body p-4">
                    <h1 class="card-title h4 mb-3">{{ 'lwndcdr-otp.verify.headline'|trans }}</h1>
                    <p class="text-muted mb-4">{{ 'lwndcdr-otp.verify.description'|trans }}</p>

                    {% for type, messages in app.flashes %}
                        {% for message in messages %}
                            <div class="alert alert-{{ type == 'danger' ? 'danger' : 'success' }}">
                                {{ message }}
                            </div>
                        {% endfor %}
                    {% endfor %}

                    <form action="{{ path('frontend.otp.verify') }}" method="post">
                        <div class="form-group mb-3">
                            <label for="otp_code" class="form-label">
                                {{ 'lwndcdr-otp.verify.codeLabel'|trans }}
                            </label>
                            <input
                                type="text"
                                id="otp_code"
                                name="otp_code"
                                class="form-control form-control-lg text-center"
                                inputmode="numeric"
                                autocomplete="one-time-code"
                                maxlength="6"
                                autofocus
                                required
                            >
                        </div>

                        <button type="submit" class="btn btn-primary w-100">
                            {{ 'lwndcdr-otp.verify.submitButton'|trans }}
                        </button>
                    </form>

                    <div class="mt-3 text-center">
                        <a href="{{ path('frontend.account.logout.page') }}" class="text-muted small">
                            {{ 'lwndcdr-otp.verify.cancelLink'|trans }}
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
