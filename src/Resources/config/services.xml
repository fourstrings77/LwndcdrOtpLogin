<?xml version="1.0" ?>

<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd">

    <services>

        <!-- Entity -->

        <service id="Lwndcdr\OtpLogin\Entity\CustomerOtp\CustomerOtpDefinition">
            <tag name="shopware.entity.definition" entity="lwndcdr_customer_otp"/>
        </service>

        <!-- Extensions -->

        <service id="Lwndcdr\OtpLogin\Core\Customer\OtpCustomerExtension">
            <tag name="shopware.entity.extension"/>
        </service>

        <!-- Core services -->

        <service id="Lwndcdr\OtpLogin\Core\Otp\TotpService">
            <argument type="service" id="Shopware\Core\System\SystemConfig\SystemConfigService"/>
        </service>

        <service id="Lwndcdr\OtpLogin\Core\Otp\OtpSessionService"/>

        <service id="lwndcdr_otp.rate_limiter.otp_verify"
                 class="Symfony\Component\RateLimiter\RateLimiterFactory">
            <factory class="Lwndcdr\OtpLogin\Core\Otp\OtpRateLimiterFactory" method="createOtpVerifyLimiter"/>
            <argument type="service" id="cache.app"/>
        </service>

        <service id="Lwndcdr\OtpLogin\Core\Otp\EmailOtpService">
            <argument type="service" id="lwndcdr_customer_otp.repository"/>
            <argument type="service" id="event_dispatcher"/>
            <argument type="service" id="Shopware\Core\System\SystemConfig\SystemConfigService"/>
        </service>

        <service id="Lwndcdr\OtpLogin\Core\Otp\OtpService">
            <argument type="service" id="lwndcdr_customer_otp.repository"/>
            <argument type="service" id="Lwndcdr\OtpLogin\Core\Otp\TotpService"/>
            <argument type="service" id="Lwndcdr\OtpLogin\Core\Otp\EmailOtpService"/>
            <argument type="service" id="Lwndcdr\OtpLogin\Core\Otp\OtpSessionService"/>
        </service>

        <!-- Subscribers -->

        <service id="Lwndcdr\OtpLogin\Subscriber\CustomerLoginSubscriber">
            <argument type="service" id="request_stack"/>
            <argument type="service" id="Lwndcdr\OtpLogin\Core\Otp\OtpService"/>
            <argument type="service" id="Lwndcdr\OtpLogin\Core\Otp\OtpSessionService"/>
            <argument type="service" id="router"/>
            <tag name="kernel.event_subscriber"/>
        </service>

        <!-- Storefront controller -->

        <service id="Lwndcdr\OtpLogin\Storefront\Controller\OtpController" public="true">
            <argument type="service" id="lwndcdr_customer_otp.repository"/>
            <argument type="service" id="Lwndcdr\OtpLogin\Core\Otp\TotpService"/>
            <argument type="service" id="Lwndcdr\OtpLogin\Core\Otp\OtpService"/>
            <argument type="service" id="Lwndcdr\OtpLogin\Core\Otp\OtpSessionService"/>
            <argument type="service" id="lwndcdr_otp.rate_limiter.otp_verify"/>
            <call method="setContainer">
                <argument type="service" id="service_container"/>
            </call>
            <tag name="controller.service_arguments"/>
        </service>

    </services>
</container>
